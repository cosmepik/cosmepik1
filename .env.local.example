# 本番・OGP用（Twitter/LINEでシェア時のプレビュー画像のURLに使用。Netlifyの場合は本番URLを指定）
# 楽天API（openapi）は Origin ヘッダにこのURLを使います。許可されたウェブサイトに一致させる必要があります。
NEXT_PUBLIC_APP_URL=https://cosmepikdemo1.netlify.app

# Supabase（認証・DB に使用。https://supabase.com でプロジェクト作成、Settings → API からコピー）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....
# 退会機能用：ユーザーが退会したときに認証アカウントも削除するために必要です。
# Supabase ダッシュボード → Settings → API の「service_role」の鍵をコピーして貼り付けてください（anon key とは別です）。
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# 楽天API（https://webservice.rakuten.co.jp/ でアプリ登録。未設定時は検索でダミーデータを使用）
RAKUTEN_APPLICATION_ID=xxxxx
RAKUTEN_ACCESS_KEY=xxxxx
